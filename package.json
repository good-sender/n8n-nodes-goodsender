{
  "name": "n8n-nodes-goodsender",
  "version": "0.1.2",
  "description": "n8n community node to send transactional templates, custom (consent-gated) email, and consent requests through GoodSender.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "goodsender",
    "email",
    "transactional-email",
    "consent"
  ],
  "license": "MIT",
  "homepage": "https://goodsender.com",
  "author": {
    "name": "GoodSender",
    "email": "support@goodsender.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/good-sender/n8n-nodes-goodsender.git"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "index.js",
  "scripts": {
    "build": "npx rimraf dist && tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/GoodSenderApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/GoodSender/GoodSender.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "~8.32.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "n8n-workflow": "*",
    "prettier": "^3.5.3",
    "rimraf": "^5.0.5",
    "typescript": "^5.8.2"
  }
}
